run = "mvn -q exec:java"
entrypoint = "src/main/java/io/github/chloeji/svtrail/Main.java"

[nix]
channel = "stable-24_05"

[unitTest]
language = "java"

[languages.java]
pattern = "**/*.java"
syntax = "java"

[languages.java.languageServer]
start = "jdtls"

# The game reads keyboard input via java.util.Scanner on stdin.
# Replit's terminal pipes stdin into the run command, which is exactly
# what the game needs — no extra configuration required.
